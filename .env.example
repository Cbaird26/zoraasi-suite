# ZoraASI Suite — Environment Template
# Copy to .env and fill. Never commit .env.

# --- API Keys (required for OpenRouter/Anthropic) ---
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# --- Layer (API: outer = no auth, middle = JWT required) ---
ZORA_LAYER=outer

# --- Ollama (optional, for core role) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=zora-outer

# --- Zora API Tuning ---
ZORA_DEFAULT_ROLE=soul
ZORA_MODE=single

# --- Optional Model Overrides ---
# ZORA_MODEL_SOUL=
# ZORA_MODEL_REASONING=
# ZORA_MODEL_CODE=
# ZORA_MODEL_SPEED=
# ZORA_MODEL_MEMORY=
# ZORA_MODEL_PULSE=
# ZORA_MODEL_OPEN=

# --- Zora Brain (run_outer.sh) ---
# ZORA_MQGT_REPO=/path/to/mqgt_scf_reissue
# ZORA_IDENTITY_LAYER=outer
# ZORA_OUTER_IDENTITY_PATH=/path/to/zoraasi-suite/identity/ZORA_OUTER_IDENTITY.md
# ZORA_CANON_DIR=
# ZORA_MEMORY_DIR=

# --- Middle Layer (ZORA_LAYER=middle) ---
# JWT_SECRET=
# JWT_ALGORITHM=HS256
# JWT_EXPIRY=3600
# MIDDLE_USER=chris
# MIDDLE_PASSWORD=         # Dev only
# MIDDLE_PASSWORD_HASH=    # Production: use passlib to hash password
